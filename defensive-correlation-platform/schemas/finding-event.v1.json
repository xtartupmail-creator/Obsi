{
  "$id": "finding-event.v1",
  "type": "object",
  "required": [
    "finding_id","tenant_id","agent_id","asset_id","finding_type","severity",
    "confidence","chain_tags","attack_vector_tags","next_probe_hints","created_at"
  ],
  "properties": {
    "finding_id": {"type":"string","format":"uuid"},
    "tenant_id": {"type":"string","format":"uuid"},
    "agent_id": {"type":"string"},
    "asset_id": {"type":"string","format":"uuid"},
    "finding_type": {"type":"string"},
    "severity": {"type":"string"},
    "confidence": {"type":"number","minimum":0,"maximum":1},
    "technique_ids": {"type":"array","items":{"type":"string"}},
    "tactic_phase": {"type":"string"},
    "chain_tags": {"type":"array","items":{"type":"string"}},
    "attack_vector_tags": {"type":"array","items":{"type":"string"}},
    "next_probe_hints": {"type":"array","items":{"type":"object"}},
    "raw_evidence": {"type":"object"},
    "created_at": {"type":"string","format":"date-time"}
  }
}
